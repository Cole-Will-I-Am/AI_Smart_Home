# /etc/homeops/secrets.env — MUST be chmod 0600, owned by the service user.
# The service refuses to start if this file is group/other-readable.
# Environment variables with the same names override these values.
HOMEOPS_HA_URL=https://ha-house-a.internal:8123
HOMEOPS_HA_TOKEN=REPLACE_long_lived_access_token
#HOMEOPS_OPN_URL=https://opnsense-a.internal
#HOMEOPS_OPN_KEY=REPLACE
#HOMEOPS_OPN_SECRET=REPLACE
# Required whenever dash_host is non-loopback:
HOMEOPS_DASH_TOKEN=REPLACE_random_bearer_token
